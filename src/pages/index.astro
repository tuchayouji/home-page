---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <div id="wrapper">
    <!-- 背景（随机选图，repeat-x横向平铺+缓慢滚动，跟模版一样） -->
    <div id="bg"></div>
    <script is:inline>
      (function() {
        var images = ['/bg/bg1.jpg', '/bg/bg2.jpg', '/bg/bg3.jpg', '/bg/bg4.jpg'];
        var bg = document.getElementById('bg');
        if (bg) {
          var img = images[Math.floor(Math.random() * images.length)];
          // 跟模版main.css一样：repeat-x平铺，auto 100%铺满高，横向滚动
          bg.style.background = "url('" + img + "') center left / auto 100% repeat-x #ffffff";
        }
      })();
    </script>
    <div id="overlay"></div>
    <div id="main">
      <!-- Header -->
      <header id="header">
        <div class="panel-main__content">
          <!-- 头像（带翻转效果） -->
          <div class="ih-item circle effect right_to_left">
            <a class="blog-button">
              <div class="img">
                <img src="/avatar.jpg" alt="Tucha" class="js-avatar iUp profilepic header-logo" />
              </div>
              <div class="info iUp">
                <div class="info-back">
                  <img alt="Tucha" src="/avatar.jpg" class="js-avatar profilepic" />
                </div>
              </div>
            </a>
          </div>

          <!-- 名字 -->
          <h1 class="panel-cover__title panel-title iUp">Tucha</h1>
          <p class="panel-cover__subtitle panel-subtitle iUp">Stay hungry, stay foolish</p>

          <!-- 时钟 -->
          <canvas class="navigation-wrapper iUp" id="canvas" style="display:block; margin:0 auto; max-width:320px; width:100%; padding-top:15px;" width="600" height="200"></canvas>
          <script src="/asset/js/clock.js" is:inline></script>

          <!-- 三个药丸按钮 -->
          <div class="pill-buttons-container iUp">
            <a href="https://blog.tuchayouji.cn" class="pill-button" target="_blank">
              <div class="pill-button-decor pill-left" style="background: linear-gradient(45deg, #f97316, #fb923c);"></div>
              <div class="pill-button-decor pill-right" style="background: linear-gradient(45deg, #ea580c, #f97316);"></div>
              <span class="pill-button-text">博客</span>
            </a>
            <a href="/projects" class="pill-button" target="_blank">
              <div class="pill-button-decor pill-left" style="background: linear-gradient(45deg, #fb923c, #fbbf24);"></div>
              <div class="pill-button-decor pill-right" style="background: linear-gradient(45deg, #f59e0b, #f97316);"></div>
              <span class="pill-button-text">项目</span>
            </a>
            <a href="/about" class="pill-button">
              <div class="pill-button-decor pill-left" style="background: linear-gradient(45deg, #fbbf24, #fcd34d);"></div>
              <div class="pill-button-decor pill-right" style="background: linear-gradient(45deg, #f59e0b, #fb923c);"></div>
              <span class="pill-button-text">关于</span>
            </a>
          </div>

          <!-- 联系方式图标 -->
          <div class="contact-icons-container iUp">
            <!-- QQ: 二维码 -->
            <a href="#" class="contact-icon qq-icon" title="QQ" style="color: #12B7F5;">
              <i class="fab fa-qq"></i>
              <div class="qq-qr">
                <img src="/bg/qqqr.jpg" alt="QQ二维码" />
              </div>
            </a>
            <!-- 微信: 二维码 -->
            <a href="#" class="contact-icon wechat-icon" title="微信" style="color: #09BB07;">
              <i class="fab fa-weixin"></i>
              <div class="wechat-qr">
                <img src="/bg/wechatqr.jpg" alt="微信二维码" />
              </div>
            </a>
            <!-- 邮箱 -->
            <a href="mailto:2389897360@qq.com" class="contact-icon" title="邮箱" style="color: #f97316;">
              <i class="fas fa-envelope"></i>
            </a>
            <!-- GitHub -->
            <a href="https://github.com/tuchayouji" class="contact-icon" target="_blank" title="GitHub" style="color: #fff;">
              <i class="fab fa-github"></i>
            </a>
            <!-- B站 -->
            <a href="https://space.bilibili.com/454303619" class="contact-icon" target="_blank" title="哔哩哔哩" style="color: #00A1D6;">
              <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
                <path d="M18.223 3.086a1.25 1.25 0 010 1.768L17.08 5.996h1.17A3.75 3.75 0 0122 9.747v7.5a3.75 3.75 0 01-3.75 3.75H5.75A3.75 3.75 0 012 17.247v-7.5a3.75 3.75 0 013.75-3.75h1.166L5.775 4.855a1.25 1.25 0 111.767-1.768l2.652 2.652c.079.079.145.165.198.257h3.213c.053-.092.12-.18.199-.258l2.651-2.652a1.25 1.25 0 011.768 0zm.027 5.42H5.75a1.25 1.25 0 00-1.247 1.157l-.003.094v7.5c0 .659.51 1.199 1.157 1.246l.093.004h12.5a1.25 1.25 0 001.247-1.157l.003-.093v-7.5c0-.69-.56-1.25-1.25-1.25zm-10 2.5c.69 0 1.25.56 1.25 1.25v1.25a1.25 1.25 0 11-2.5 0v-1.25c0-.69.56-1.25 1.25-1.25zm7.5 0c.69 0 1.25.56 1.25 1.25v1.25a1.25 1.25 0 11-2.5 0v-1.25c0-.69.56-1.25 1.25-1.25z"/>
              </svg>
            </a>
          </div>

          <hr class="iUp" />

          <!-- 个性签名 -->
          <p id="description" class="panel-cover__description iUp">这里放你的个性签名～</p>
        </div>
      </header>

      <!-- Footer -->
      <footer id="footer">
        <p>
          <b>&copy; 2026 <a href="https://tucha.cn" class="active">Tucha</a></b>
        </p>
      </footer>
    </div>
  </div>
</Layout>

<style is:global>
  /* 标题颜色 */
  #header h1 {
    color: #fff;
  }

  /* 药丸按钮悬停颜色覆盖 - 橙色系 */
  .pill-button:nth-child(1):hover {
    background: radial-gradient(circle at center, rgba(249, 115, 22, 0.15) 0%, rgba(251, 146, 60, 0.1) 40%, rgba(249, 115, 22, 0.05) 70%, transparent 100%) !important;
    backdrop-filter: blur(10px);
    box-shadow: 0 0 30px rgba(249, 115, 22, 0.4), 0 0 60px rgba(249, 115, 22, 0.2) !important;
  }

  .pill-button:nth-child(2):hover {
    background: radial-gradient(circle at center, rgba(251, 146, 60, 0.15) 0%, rgba(251, 191, 36, 0.1) 40%, rgba(251, 146, 60, 0.05) 70%, transparent 100%) !important;
    backdrop-filter: blur(10px);
    box-shadow: 0 0 30px rgba(251, 146, 60, 0.4), 0 0 60px rgba(251, 146, 60, 0.2) !important;
  }

  .pill-button:nth-child(3):hover {
    background: radial-gradient(circle at center, rgba(251, 191, 36, 0.15) 0%, rgba(252, 211, 77, 0.1) 40%, rgba(251, 191, 36, 0.05) 70%, transparent 100%) !important;
    backdrop-filter: blur(10px);
    box-shadow: 0 0 30px rgba(251, 191, 36, 0.4), 0 0 60px rgba(251, 191, 36, 0.2) !important;
  }

  #wrapper {
    animation: wrapper 3s forwards;
  }

  /* 覆盖模版微信二维码的100x100固定尺寸 */
  .wechat-qr img {
    width: 120px !important;
    height: auto !important;
    max-width: none !important;
  }

  /* QQ 二维码弹窗（跟模版微信的样式一样） */
  .qq-qr {
    position: absolute;
    bottom: 60px;
    left: 50%;
    transform: translateX(-50%);
    background: #fff;
    padding: 10px;
    border-radius: 10px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
    z-index: 100;
    white-space: nowrap;
  }
  .qq-qr img {
    width: 120px;
    height: auto;
    display: block;
    max-width: none;
  }
  .qq-icon:hover .qq-qr {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(-10px);
  }
  .qq-qr::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 8px solid transparent;
    border-top-color: #fff;
  }
</style>
